---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout title="Neexa | エンジニアのAI探索ログ">
  <Header />
  <main id="main-content" data-layout="index">
    <section id="hero" class="w-full">
      <div class="app-layout pt-8 pb-8">
        <h1 class="my-4 inline-block text-3xl font-bold sm:my-6 sm:text-4xl uppercase tracking-tight">
          NEEXA
        </h1>
        <a
          target="_blank"
          href="/rss.xml"
          class="inline-block ml-3"
          aria-label="RSSフィード"
          title="RSSフィード"
        >
          <IconRss
            width={20}
            height={20}
            class="scale-110 stroke-accent stroke-2 rtl:-rotate-90"
          />
          <span class="sr-only">RSSフィード</span>
        </a>

        <p class="text-sm max-w-2xl leading-relaxed mt-3 text-foreground/80">
          最新AIをひたすら触り続けてる人のメモ帳みたいなブログ。
        </p>
        <!-- {
          // only display if at least one social link is enabled
          SOCIALS.length > 0 && (
            <div class="mt-6 flex border-t border-border pt-3 max-sm:flex-col sm:items-center">
              <div class="me-3 mb-1 tracking-widest text-xs text-foreground/60 sm:mb-0">SNS</div>
              <Socials />
            </div>
          )
        } -->
      </div>
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class="w-full"
        >
          <div class="app-layout pt-10 pb-10">
            <h2 class="text-lg font-bold tracking-tight border-l-2 border-mint pl-3 mb-6">注目記事</h2>
            <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
              {featuredPosts.map(data => (
                <Card variant="h3" {...data} />
              ))}
            </ul>
          </div>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="w-full">
          <div class="app-layout pt-10 pb-10">
            <h2 class="text-lg font-bold tracking-tight border-l-2 border-blue pl-3 mb-6">新着記事</h2>
            <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
              {recentPosts.map(
                (data, index) =>
                  index < SITE.postPerIndex && <Card variant="h3" {...data} />
              )}
            </ul>
            <div class="mt-8 text-center">
              <LinkButton href="/posts/" class="border border-accent px-5 py-2 text-sm font-bold uppercase tracking-widest hover:bg-accent hover:text-background transition-colors">
                記事一覧を見る
                <IconArrowRight class="inline-block ml-2 rtl:-rotate-180" />
              </LinkButton>
            </div>
          </div>
        </section>
      )
    }
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
