---
import { PUBLIC_PLAUSIBLE_DOMAIN } from "astro:env/client";
import { PUBLIC_PLAUSIBLE_SCRIPT_URL } from "astro:env/client";
---

{
  PUBLIC_PLAUSIBLE_DOMAIN && PUBLIC_PLAUSIBLE_SCRIPT_URL && (
    <script
      defer
      is:inline
      data-domain={PUBLIC_PLAUSIBLE_DOMAIN}
      src={PUBLIC_PLAUSIBLE_SCRIPT_URL}
    />
  )
}
