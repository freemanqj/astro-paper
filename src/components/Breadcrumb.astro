---
// Remove current url path and remove trailing slash if exists
const currentUrlPath = Astro.url.pathname.replace(/\/+$/, "");

// Get url array from path
// eg: /tags/tailwindcss => ['tags', 'tailwindcss']
const breadcrumbList = currentUrlPath.split("/").slice(1);

// if breadcrumb is ホーム > 記事一覧 > 1 <etc>
// replace 記事一覧 with 記事一覧 (page number)
if (breadcrumbList[0] === "posts") {
  breadcrumbList.splice(0, 2, `記事一覧（${breadcrumbList[1] || 1}ページ目）`);
}

// if breadcrumb is ホーム > タグ > [tag] > [page] <etc>
// replace [tag] > [page] with [tag] (page number)
if (breadcrumbList[0] === "tags" && !isNaN(Number(breadcrumbList[2]))) {
  breadcrumbList.splice(
    1,
    3,
    `${breadcrumbList[1]}${Number(breadcrumbList[2]) === 1 ? "" : `（${breadcrumbList[2]}ページ目）`}`
  );
}

const breadcrumbLabelMap: Record<string, string> = {
  posts: "記事一覧",
  tags: "タグ",
  about: "このサイトについて",
  archives: "アーカイブ",
  search: "検索",
  privacy: "プライバシーポリシー",
  terms: "利用規約",
};

const formatBreadcrumb = (breadcrumb: string) =>
  breadcrumbLabelMap[breadcrumb] ?? decodeURIComponent(breadcrumb);
---

<nav class="app-layout mt-8 mb-1" aria-label="パンくずリスト">
  <ul
    class="font-light [&>li]:inline [&>li:not(:last-child)>a]:hover:opacity-100"
  >
    <li>
      <a href="/" class="opacity-80">ホーム</a>
      <span aria-hidden="true" class="opacity-80">&raquo;</span>
    </li>
    {
      breadcrumbList.map((breadcrumb, index) =>
        index + 1 === breadcrumbList.length ? (
          <li>
            <span
              class:list={["capitalize opacity-75", { lowercase: index > 0 }]}
              aria-current="page"
            >
              {formatBreadcrumb(breadcrumb)}
            </span>
          </li>
        ) : (
          <li>
            <a href={`/${breadcrumb}/`} class="capitalize opacity-70">
              {formatBreadcrumb(breadcrumb)}
            </a>
            <span aria-hidden="true">&raquo;</span>
          </li>
        )
      )
    }
  </ul>
</nav>
