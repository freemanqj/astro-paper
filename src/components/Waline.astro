---
const serverURL = import.meta.env.PUBLIC_WALINE_SERVER_URL ?? "";
const lang = import.meta.env.PUBLIC_WALINE_LANG ?? "ja";
const pagePath = `${Astro.url.host}${Astro.url.pathname}`;
---

<link
  rel="stylesheet"
  href="https://unpkg.com/@waline/client@v3/dist/waline.css"
/>

<section class="mt-10">
  <h2 class="mb-4 text-lg font-bold tracking-tight uppercase border-l-2 border-blue pl-3">
    コメント
  </h2>
  <div
    id="waline"
    data-server-url={serverURL}
    data-page-path={pagePath}
    data-lang={lang}
  ></div>
</section>

<style>
  :global(#waline .wl-power),
  :global(#waline .wl-footer a),
  :global(#waline .wl-rss),
  :global(#waline .wl-user-avatar),
  :global(#waline .wl-user-agent),
  :global(#waline .wl-badge),
  :global(#waline .wl-meta) {
    display: none !important;
  }
</style>

<script is:inline type="module">
  import { init } from "https://unpkg.com/@waline/client@v3/dist/waline.js";

  function mountWaline() {
    const el = document.getElementById("waline");
    if (!el || el.dataset.walineInit === "1") return;
    el.dataset.walineInit = "1";

    const serverURL = el.dataset.serverUrl || "";
    const path = el.dataset.pagePath || window.location.pathname;
    const lang = el.dataset.lang || "ja";
    const getTheme = () =>
      document.documentElement.getAttribute("data-theme") === "dark"
        ? "dark"
        : "light";

    if (!serverURL) return;

    const waline = init({
      el,
      serverURL,
      path,
      lang,
      login: "disable",
      requiredMeta: ["nick", "mail"],
      avatar: "mp",
      reaction: false,
      imageUploader: false,
      uploadImage: false,
      theme: getTheme(),
    });

    const observer = new MutationObserver(() => {
      try {
        waline?.update?.({ theme: getTheme() });
      } catch {
        // noop
      }
    });

    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["data-theme"],
    });
  }

  function lazyMount() {
    const el = document.getElementById("waline");
    if (!el) return;

    const start = () => {
      if ("requestIdleCallback" in window) {
        window.requestIdleCallback(() => mountWaline());
      } else {
        setTimeout(() => mountWaline(), 0);
      }
    };

    if (!("IntersectionObserver" in window)) {
      start();
      return;
    }

    const observer = new IntersectionObserver(
      entries => {
        if (entries.some(entry => entry.isIntersecting)) {
          observer.disconnect();
          start();
        }
      },
      { rootMargin: "200px 0px" }
    );

    observer.observe(el);
  }

  lazyMount();
  document.addEventListener("astro:page-load", lazyMount);
  document.addEventListener("astro:after-swap", lazyMount);
</script>
