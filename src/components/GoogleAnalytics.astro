---
import { PUBLIC_GOOGLE_ANALYTICS_ID } from "astro:env/client";
---

{
  PUBLIC_GOOGLE_ANALYTICS_ID && (
    <>
      <script
        async
        is:inline
        src={`https://www.googletagmanager.com/gtag/js?id=${PUBLIC_GOOGLE_ANALYTICS_ID}`}
      />
      <script is:inline define:vars={{ PUBLIC_GOOGLE_ANALYTICS_ID }}>
        window.dataLayer = window.dataLayer || [];
        function gtag() {
          dataLayer.push(arguments);
        }
        gtag("js", new Date());
        gtag("config", PUBLIC_GOOGLE_ANALYTICS_ID);
      </script>
    </>
  )
}
