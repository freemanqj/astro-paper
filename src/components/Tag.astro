---
import IconHash from "@/assets/icons/IconHash.svg";

type Props = {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
};

const { tag, tagName, size = "lg" } = Astro.props;
---

<li>
  <a
    href={`/tags/${tag}/`}
    transition:name={tag}
    class:list={[
      "inline-flex items-center gap-1 font-bold uppercase tracking-widest",
      "bg-muted px-2 py-1 border border-border transition-colors",
      "hover:bg-accent hover:text-background",
      "focus-visible:ring-2 focus-visible:ring-accent",
      { "text-xs": size === "sm" },
      { "text-sm": size === "lg" },
    ]}
  >
    <IconHash
      class:list={[
        "opacity-80",
        { "size-5": size === "lg" },
        { "size-4": size === "sm" },
      ]}
    />
    {tagName}
  </a>
</li>
